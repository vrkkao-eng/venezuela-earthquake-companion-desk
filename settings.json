{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-prohibited-domains.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(modules/routing/**)",
            "command": "bash .claude/hooks/run-module-tests.sh routing"
          },
          {
            "type": "command",
            "if": "Edit(modules/codec/**)",
            "command": "bash .claude/hooks/run-module-tests.sh codec"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-field-critical-verified.sh"
          }
        ]
      }
    ]
  }
}
